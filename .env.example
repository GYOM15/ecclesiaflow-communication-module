# EcclesiaFlow Email Module - Environment Variables
# Copy this file to .env and update with your actual values

# Server Configuration
SERVER_PORT=8082
SPRING_PROFILES_ACTIVE=dev

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=8889
DB_NAME=email_module_db
DB_USERNAME=root
DB_PASSWORD=root

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_ENABLED=false

# RabbitMQ Queue Names (Optional - use for environment separation)
# Uncomment and customize for dev/staging/prod environments
# RABBITMQ_EXCHANGE_EMAIL=dev-ecclesiaflow.communication.exchange
# RABBITMQ_QUEUE_EMAIL_SEND=dev-ecclesiaflow.communication.send.queue
# RABBITMQ_QUEUE_EMAIL_RETRY=dev-ecclesiaflow.communication.retry.queue
# RABBITMQ_QUEUE_EMAIL_DLQ=dev-ecclesiaflow.communication.dlq
# RABBITMQ_ROUTING_KEY_EMAIL_SEND=communication.send.*
# RABBITMQ_ROUTING_KEY_EMAIL_RETRY=communication.retry.*

# Email Configuration (Gmail)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here
MAIL_FROM=noreply@ecclesiaflow.com

# SendGrid (Optional)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_ENABLED=false

# AWS SES (Optional)
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here
AWS_SES_ENABLED=false

# gRPC Configuration
GRPC_ENABLED=true
GRPC_SERVER_PORT=9092

# Email Branding
EMAIL_LOGO_URL=https://your-domain.com/images/logo.png
