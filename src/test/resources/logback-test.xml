<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%nopex</pattern>
        </encoder>
    </appender>

    <logger name="org.springframework" level="WARN" />
    <logger name="org.hibernate" level="WARN" />
    <logger name="com.ecclesiaflow.communication.web.exception.GlobalExceptionHandler" level="ERROR" />

    <root level="WARN">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>
